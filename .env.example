# ==========================================
# Inkbox 邮件发送服务配置
# ==========================================
# 你的 Inkbox API 密钥 (用于通过其服务发信)
INKBOX_API_KEY=ApiKey_your_key_here
# 发件人身份标识 (在 Inkbox 系统中注册的唯一身份句柄)
INKBOX_IDENTITY_HANDLE=outreach-agent
# 发件人显示名称 (邮件中收件人看到的你的名字，外显名)
INKBOX_IDENTITY_DISPLAY_NAME=Chloe
# 邮件正文末尾默认使用的落款署名 (例如 Best, Chloe)
DEFAULT_SIGNATURE_NAME=Chloe
# 你在此项目中设定的发件箱邮箱地址
INKBOX_IDENTITY_EMAIL=hirepilot_outreach@inkboxmail.com
# 审核/安全模式下的内部接收邮箱 (当命令行未加 --live 开关时，邮件默认只会发到这个邮箱供你预览)
OUTREACH_REVIEW_EMAIL=chloezzx@bu.edu

# ==========================================
# 全局安全与行为控制
# ==========================================
# 是否允许向爬取到的真实客户邮箱进行实际发送？(强烈建议在确认无误前保持 false)
ALLOW_LIVE_OUTREACH=false

# ==========================================
# AI 模型生成服务配置 (兼容 OpenAI 接口)
# ==========================================
# 调用大模型 API 服务的鉴权密钥
OPENAI_API=sk_your_key_here
# 大模型名称 (如果直连官方，例如 gpt-5，gpt-4)
OPENAI_MODEL=gpt-5
# 模型服务的基础请求地址 (直连官方留空；本地服务需带 /v1)
OPENAI_BASE_URL=

# 是否开启 HTTP/HTTPS 代理接管请求？
# 注意：配置设为 false 时，代码主动丢弃隐式系统全局代理参数。
OPENAI_PROXY_ENABLED=false
# 显式指派的代理访问端点 (若设为 true 则本项必填，例如 http://127.0.0.1:7890)
OPENAI_PROXY_URL=
